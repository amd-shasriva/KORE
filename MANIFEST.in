include README.md
include pyproject.toml
include requirements-conductor.txt
include conftest.py
include .gitleaks.toml

recursive-include kore *.py *.yaml *.json *.jsonl *.md
recursive-include tests *.py *.md
recursive-include scripts *.py *.sh *.sbatch *.md
recursive-include configs *.json *.yaml *.yml *.md
recursive-include docs *.md
recursive-include .github *.yml *.yaml *.txt

global-exclude __pycache__ *.py[cod]
prune build
prune dist
